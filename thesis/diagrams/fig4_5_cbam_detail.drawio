    <mxCell id="formula_title" value="CBAM数学公式说明" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=13;fontColor=#996600;" vertex="1" parent="1">
      <mxGeometry x="75" y="418" width="300" height="24" as="geometry" />
    </mxCell>
    <mxCell id="formula_1" value="通道注意力：  Mc(F) = σ(MLP(AvgPool(F)) + MLP(MaxPool(F)))" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1">
      <mxGeometry x="75" y="448" width="660" height="24" as="geometry" />
    </mxCell>
    <mxCell id="formula_2" value="空间注意力：  Ms(F') = σ(Conv7×1([AvgPool_ch(F'); MaxPool_ch(F')]))" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1">
      <mxGeometry x="75" y="476" width="660" height="24" as="geometry" />
    </mxCell>
    <mxCell id="formula_3" value="串联输出：     F'' = Ms(F') ⊗ F'  其中  F' = Mc(F) ⊗ F" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1">
