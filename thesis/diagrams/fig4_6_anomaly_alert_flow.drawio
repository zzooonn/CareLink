<mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />

    <!-- TITLE -->
    <mxCell id="title" value="图4.6 健康异常检测与Guardian通知流程图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="134" y="10" width="900" height="36" as="geometry" />
    </mxCell>

    <!-- ===== START ===== -->
    <mxCell id="start" value="开始" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="530" y="60" width="100" height="46" as="geometry" />
    </mxCell>

    <!-- Step 1: receive data -->
    <mxCell id="s1" value="接收健康数据提交请求&#xa;POST /api/health/vitals&#xa;{ systolic, diastolic, bloodGlucose, ... }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="470" y="130" width="220" height="65" as="geometry" />
    </mxCell>
    <mxCell id="a_start_s1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#333;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="start" target="s1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Step 2: save record -->
    <mxCell id="s2" value="INSERT user_health_records&#xa;（保存原始记录）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="490" y="225" width="180" height="50" as="geometry" />
    </mxCell>
    <mxCell id="a_s1_s2" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#333;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="s1" target="s2">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Decision: blood pressure check -->
    <mxCell id="d_bp" value="血压异常？&#xa;SBP≥140 OR DBP≥90&#xa;（高血压标准）" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="470" y="305" width="220" height="80" as="geometry" />
    </mxCell>
    <mxCell id="a_s2_dbp" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#333;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="s2" target="d_bp">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- YES: mark abnormal BP -->
    <mxCell id="bp_abnormal" value="标记 is_abnormal=true&#xa;alert_type=BLOOD_PRESSURE&#xa;生成报警消息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="740" y="315" width="180" height="60" as="geometry" />
    </mxCell>
    <mxCell id="a_dbp_yes" value="是" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;strokeWidth=2;fontColor=#b85450;fontStyle=1;endArrow=block;endFill=1;" edge="1" parent="1" source="d_bp" target="bp_abnormal">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Decision: blood glucose check -->
    <mxCell id="d_bg" value="血糖异常？&#xa;非空腹≥200 mg/dL&#xa;OR 空腹≥126 mg/dL" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="470" y="415" width="220" height="80" as="geometry" />
    </mxCell>
    <mxCell id="a_dbp_no" value="否" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;strokeWidth=2;fontColor=#006633;fontStyle=1;endArrow=block;endFill=1;" edge="1" parent="1" source="d_bp" target="d_bg">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- YES: mark abnormal glucose -->
    <mxCell id="bg_abnormal" value="标记 is_abnormal=true&#xa;alert_type=BLOOD_GLUCOSE&#xa;生成报警消息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="740" y="425" width="180" height="60" as="geometry" />
    </mxCell>
    <mxCell id="a_dbg_yes" value="是" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;strokeWidth=2;fontColor=#b85450;fontStyle=1;endArrow=block;endFill=1;" edge="1" parent="1" source="d_bg" target="bg_abnormal">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Decision: any anomaly? -->
    <mxCell id="d_any" value="存在异常标记？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="480" y="525" width="200" height="60" as="geometry" />
    </mxCell>
    <mxCell id="a_dbg_no" value="否" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;strokeWidth=2;fontColor=#006633;fontStyle=1;endArrow=block;endFill=1;" edge="1" parent="1" source="d_bg" target="d_any">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="a_bp_to_any" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;strokeWidth=1;dashed=1;endArrow=open;" edge="1" parent="1" source="bp_abnormal" target="d_any">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="830" y="380" />
          <mxPoint x="830" y="555" />
          <mxPoint x="680" y="555" />
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="a_bg_to_any" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;strokeWidth=1;dashed=1;endArrow=open;" edge="1" parent="1" source="bg_abnormal" target="d_any">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="830" y="490" />
          <mxPoint x="830" y="555" />
          <mxPoint x="680" y="555" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- NO: normal return -->
    <mxCell id="s_normal" value="返回正常记录结果&#xa;HTTP 200 { isAbnormal: false }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="220" y="525" width="200" height="60" as="geometry" />
    </mxCell>
    <mxCell id="a_any_no" value="否" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;strokeWidth=2;fontColor=#006633;fontStyle=1;endArrow=block;endFill=1;" edge="1" parent="1" source="d_any" target="s_normal">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- YES: query guardians -->
    <mxCell id="s_query_g" value="查询 user_guardian_links&#xa;WHERE patient_id=userId&#xa;AND status='ACTIVE'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="480" y="620" width="200" height="60" as="geometry" />
    </mxCell>
    <mxCell id="a_any_yes" value="是" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;strokeWidth=2;fontColor=#b85450;fontStyle=1;endArrow=block;endFill=1;" edge="1" parent="1" source="d_any" target="s_query_g">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Decision: has guardians? -->
    <mxCell id="d_has_g" value="存在绑定的&#xa;照护者？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="490" y="710" width="180" height="70" as="geometry" />
    </mxCell>
    <mxCell id="a_qg_dg" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#333;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="s_query_g" target="d_has_g">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- YES: insert alert per guardian -->
    <mxCell id="s_insert_alert" value="FOR EACH guardian:&#xa;INSERT user_health_alert&#xa;{ patient_id, guardian_id,&#xa;  record_id, alert_type, message }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="720" y="710" width="210" height="75" as="geometry" />
    </mxCell>
    <mxCell id="a_dg_yes" value="是" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;strokeWidth=2;fontColor=#b85450;fontStyle=1;endArrow=block;endFill=1;" edge="1" parent="1" source="d_has_g" target="s_insert_alert">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Return with alert -->
    <mxCell id="s_return_alert" value="返回异常记录结果&#xa;HTTP 200 { isAbnormal: true,&#xa;alertsSent: N }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="490" y="820" width="200" height="65" as="geometry" />
    </mxCell>
    <mxCell id="a_alert_return" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="s_insert_alert" target="s_return_alert">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="825" y="785" />
          <mxPoint x="825" y="852" />
          <mxPoint x="690" y="852" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- No guardian: return alert without notify -->
    <mxCell id="s_no_g" value="记录异常但无通知对象&#xa;HTTP 200 { isAbnormal: true,&#xa;alertsSent: 0 }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="270" y="725" width="190" height="65" as="geometry" />
    </mxCell>
    <mxCell id="a_dg_no" value="否" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;strokeWidth=2;fontColor=#996600;fontStyle=1;endArrow=block;endFill=1;" edge="1" parent="1" source="d_has_g" target="s_no_g">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ===== THRESHOLD BOX ===== -->
    <mxCell id="thresh_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;opacity=50;" vertex="1" parent="1">
      <mxGeometry x="60" y="305" width="370" height="190" as="geometry" />
    </mxCell>
    <mxCell id="thresh_title" value="临床异常阈值一览" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=12;fontColor=#996600;" vertex="1" parent="1">
      <mxGeometry x="75" y="312" width="200" height="24" as="geometry" />
    </mxCell>
    <mxCell id="thresh_1" value="🩸 血压（高血压）：收缩压 ≥ 140 mmHg OR 舒张压 ≥ 90 mmHg" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="75" y="340" width="340" height="24" as="geometry" />
    </mxCell>
    <mxCell id="thresh_2" value="🩸 血压（低血压）：收缩压 ≤ 90 mmHg OR 舒张压 ≤ 60 mmHg" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="75" y="364" width="340" height="24" as="geometry" />
    </mxCell>
    <mxCell id="thresh_3" value="🍬 血糖（非空腹）：≥ 200 mg/dL（糖尿病标准）" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="75" y="388" width="340" height="24" as="geometry" />
    </mxCell>
    <mxCell id="thresh_4" value="🍬 血糖（空腹）：≥ 126 mg/dL（ADA标准）" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="75" y="412" width="340" height="24" as="geometry" />
    </mxCell>
    <mxCell id="thresh_5" value="❤️ ECG风险：HIGH/MEDIUM → 同步触发报警" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="75" y="436" width="340" height="24" as="geometry" />
    </mxCell>
    <mxCell id="thresh_6" value="数据来源：JNC8 / AHA 2017 / ADA 2023临床指南" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontStyle=3;fontColor=#666666;" vertex="1" parent="1">
      <mxGeometry x="75" y="468" width="340" height="20" as="geometry" />
